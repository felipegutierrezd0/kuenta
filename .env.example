# Pon "true" para usar la app con datos falsos en memoria, sin necesitar Supabase (ideal para probar la app).
# Cuando ya tengas tu proyecto de Supabase listo, cambia esto a "false" y completa las llaves de abajo.
EXPO_PUBLIC_DEMO_MODE=true

EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
